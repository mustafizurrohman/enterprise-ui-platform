{
  "name": "Enterprise UI Platform",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "postCreateCommand": "npm ci",
  "forwardPorts": [
    6006
  ],
  "portsAttributes": {
    "6006": {
      "label": "Storybook",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Angular.ng-template",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postStartCommand": "npm run storybook"
}
